from rclpy.node import node
from std.msgs.msg import string
import json
import time
import cv2

max_people = 10
announce_interval = 5

def pub(jmcd):
    msg = String()
    msg.data = json.dump(jmcd)
    armheadpub.publish(msg)

def speak(text):
    msg = String()
    msg.data = text
    ttspub.publish(msg)

def look_at_person(x, frame_width):
    center = frame_width / 2
    offset = (x - center) / center

    hx = int(-offset * 30)

    hx = max(-35, min(35, hx))

    pub({"cmd": f"ms:400,hx:{hx}"})

def announce_count(count):
    if count == 0:
        speak("deep I see no people here")
    elif count == 1:
        speak("deep I see one person")
    elif count < max_people:
        speak (f"deep I see {count} people")
    else:
        speak("deep There are many people here")

